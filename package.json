{
  "name": "kios-annajah-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:monitoring": "vite --mode monitoring --host 0.0.0.0 --open",
    "build:backend": "node scripts/build-backend.mjs",
    "build:web": "tsc && vite build --mode monitoring",
    "build:desktop": "npm run build:backend && tsc && vite build && electron-builder",
    "build": "npm run build:desktop",
    "preview:web": "vite preview --host 0.0.0.0 --port 4173 --open",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.kiosannajah.desktop",
    "productName": "Kios An-Najah",
    "executableName": "KiosAnNajah",
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kios An-Najah",
      "uninstallDisplayName": "Kios An-Najah",
      "installerHeaderIcon": "build/icons/icon.ico",
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    }
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
